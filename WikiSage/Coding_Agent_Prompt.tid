### External API Integration
```javascript
/*\
title: $:/plugins/myname/api-integration/modules/api-requester
type: application/javascript
module-type: library

API integration helper

\*/
(function(){

/*jslint node: true, browser: true */
/*global $tw: false */
"use strict";

exports.fetchData = function(url, options) {
    options = options || {};
    return fetch(url, {
        method: options.method || "GET",
        headers: options.headers || {
            "Content-Type": "application/json"
        },
        body: options.body ? JSON.stringify(options.body) : undefined
    })
    .then(response => {
        if (!response.ok) {
            throw new Error("API request failed: " + response.statusText);
        }
        return response.json();
    })
    .then(data => {
        if (options.targetTiddler) {
            $tw.wiki.setText(options.targetTiddler, "text", null, 
                              JSON.stringify(data, null, 2));
        }
        return data;
    })
    .catch(error => {
        console.error("API error:", error);
        if (options.errorTiddler) {
            $tw.wiki.setText(options.errorTiddler, "text", null, error.message);
        }
        throw error;
    });
};

})();
```

