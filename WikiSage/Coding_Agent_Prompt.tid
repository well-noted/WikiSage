### Performance Analysis
```javascript
/*\
title: $:/plugins/myname/devtools/modules/performance
type: application/javascript
module-type: startup

Performance measurement tools

\*/
(function(){

/*jslint node: true, browser: true */
/*global $tw: false */
"use strict";

exports.name = "performance-tools";
exports.platforms = ["browser"];
exports.after = ["render"];
exports.synchronous = true;

exports.startup = function() {
    // Track widget refresh performance
    var originalRefresh = $tw.Widget.prototype.refresh;
    $tw.Widget.prototype.refresh = function(changedTiddlers) {
        if ($tw.wiki.getTiddlerText("$:/config/PerformanceMonitoring") === "yes") {
            var start = performance.now();
            var result = originalRefresh.call(this, changedTiddlers);
            var end = performance.now();
            if (end - start > 50) { // Log only slow operations
                console.log("Slow widget refresh:", this, (end - start).toFixed(2) + "ms");
            }
            return result;
        } else {
            return originalRefresh.call(this, changedTiddlers);
        }
    };
    
    // Add performance monitoring for filter execution
    var originalFilterFn = $tw.wiki.filterTiddlers;
    $tw.wiki.filterTiddlers = function(filterString, widget, source) {
        if ($tw.wiki.getTiddlerText("$:/config/PerformanceMonitoring") === "yes") {
            var start = performance.now();
            var results = originalFilterFn.call(this, filterString, widget, source);
            var end = performance.now();
            if (end - start > 20) { // Log only slow filters
                console.log("Slow filter:", filterString, (end - start).toFixed(2) + "ms", results.length + " results");
            }
            return results;
        } else {
            return originalFilterFn.call(this, filterString, widget, source);
        }
    };
};

})();
```

